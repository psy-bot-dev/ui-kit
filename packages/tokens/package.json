  },
  "files": [
    "dist",
    "src/css"
  ],
  "sideEffects": [
    "*.css"
  ],
  "peerDependencies": {
    "vue": ">=3.5.0",
    "tailwindcss": ">=3.4.0"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.5.0"
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "vue-tsc --noEmit"
